rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isDataOwner() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    function isExistingOwner() {
      return isSignedIn() && request.auth.uid == resource.data.userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['name', 'email', 'xp', 'level']) && request.resource.data.xp == 0 && request.resource.data.level == 1;
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'focusTime', 'breakTime', 'xp', 'level', 'badges']);
    }

    // Identities
    match /identities/{identityId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner() && request.resource.data.name.size() > 0;
      allow update: if isExistingOwner() && isDataOwner() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description']);
      allow delete: if isExistingOwner();
    }

    // Habits
    match /habits/{habitId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow update: if isExistingOwner() && isDataOwner();
      allow delete: if isExistingOwner();
    }

    // Logs
    match /logs/{logId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow delete: if isExistingOwner();
    }

    // Reflections
    match /reflections/{reflectionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow delete: if isExistingOwner();
    }

    // Experiments
    match /experiments/{experimentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isDataOwner();
      allow update: if isExistingOwner() && isDataOwner();
      allow delete: if isExistingOwner();
    }
  }
}
